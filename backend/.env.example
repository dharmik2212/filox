# FastAPI Config
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Filox API

# Database
DATABASE_URL=sqlite:///./filox.db
# For production: postgresql://user:password@localhost/filox

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT
SECRET_KEY=your_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ML Model
MODEL_PATH=app/ml/models/academic_classifier_v1.pt
MODEL_VERSION=1.0

# Environment
ENVIRONMENT=development
